---
import Layout from "../layouts/Layout.astro";
import Eyebrow from "../components/Eyebrow.astro";

const lines = [
  {
    n: "01",
    name: "Ultrasonic & Phased-Array",
    badge: "PAUT · TFM · FMC",
    bullets: [
      "Weld inspection",
      "Composite C-scan and laminate delamination mapping",
      "Corrosion / creep-fatigue monitoring",
      "Trent-class engine inspection precedent (Rolls-Royce TI0175 / TI0182 / TI0183)",
    ],
  },
  {
    n: "02",
    name: "Magnetic-Particle & Penetrant",
    badge: "MT · PT",
    bullets: [
      "Hydrophilic, lipophilic, and solvent-removable fluorescent penetrant",
      "Wet-bench or portable yoke MT with residual-field verification",
    ],
  },
  {
    n: "03",
    name: "Eddy-Current & Eddy Current Array",
    badge: "ET · ECA",
    bullets: [
      "Fastener-hole, rotor-bore, and conductivity surveys",
      "Eddy Current Array program development and execution",
    ],
  },
  {
    n: "04",
    name: "Level III Quality & Consulting",
    badge: "ASNT Level III",
    bullets: [
      "Procedure writing & approval — NAS 410, ISO 9712",
      "Technician examinations, eye tests, mock NADCAP AC7114 audits",
      "Root-cause analysis and CAPA implementation",
      "QMS gap analysis against AS9100 / ISO 9001",
    ],
  },
  {
    n: "05",
    name: "Classroom Formal Training",
    badge: "ASNT SNT-TC-1A · NAS 410",
    bullets: [
      "Instructor-led NDT method courses delivered in accordance with SNT-TC-1A and NAS 410",
      "Method coverage: UT, PAUT/FMC, MT, PT, ET/ECA, VT",
      "Level I, Level II, and Level III preparation",
      "POD and data-analytics workshops on request",
    ],
  },
];

const engagements = [
  ["Mobilized Field Crew", "Short-term surge, remote site",      "Level II technicians, calibrated gear, consumables, travel"],
  ["Embedded Technician", "Long-term production line",           "Hourly or weekly contract under your written practice"],
  ["Data-Only Review",     "Sign-off on internal scans",          "Secure upload → Level III formal interpretation"],
  ["POD & Reliability",    "New-process certification",           "Specimen design, flaw manufacture, statistical analysis"],
  ["Training Engagement",  "Workforce upskilling",                "SNT-TC-1A / NAS 410 classroom courses, on-site or virtual"],
];
---
<Layout title="Services">
  <section class="page-head shell">
    <Eyebrow number="00" label="Services" />
    <h1 class="page-head__h">Mission-critical NDT and quality-engineering services.</h1>
    <p class="lead page-head__lead">
      Five service lines, four standing engagement models, one consistent operating principle:
      <em>audit-ready documentation, statistically proven detection.</em>
    </p>
  </section>

  <!-- Service lines -->
  <section class="section shell">
    <Eyebrow number="01" label="Service lines" />
    <ol class="lines bare">
      {lines.map(({ n, name, badge, bullets }) => (
        <li class="line">
          <div class="line__head">
            <span class="line__n">§ {n}</span>
            <h3 class="line__name">{name}</h3>
            <span class="cred line__badge">{badge}</span>
          </div>
          <ul class="bare line__bullets">
            {bullets.map((b) => <li>{b}</li>)}
          </ul>
        </li>
      ))}
    </ol>
  </section>

  <!-- Engagement models -->
  <section class="section shell">
    <Eyebrow number="02" label="How we engage" />
    <h2 class="section-h">Five ways to bring HNEC into a program.</h2>

    <div class="table-wrap">
      <table class="eng-table">
        <thead>
          <tr>
            <th scope="col">Model</th>
            <th scope="col">Best for</th>
            <th scope="col">What's included</th>
          </tr>
        </thead>
        <tbody>
          {engagements.map(([model, fit, included]) => (
            <tr>
              <th scope="row">{model}</th>
              <td>{fit}</td>
              <td>{included}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Standards & credentials -->
  <section class="section shell">
    <Eyebrow number="03" label="Standards & credentials" />
    <ul class="bare standards">
      <li>AWS&nbsp;D17.1</li>
      <li>NASA&nbsp;STD-5009</li>
      <li>MIL-HDBK-1823A</li>
      <li>NADCAP&nbsp;AC7114</li>
      <li>NAS&nbsp;410</li>
      <li>ASNT&nbsp;SNT-TC-1A</li>
      <li>ISO&nbsp;9712</li>
      <li>AS9100</li>
      <li>ISO&nbsp;9001</li>
    </ul>

    <p class="cred-line">
      <span class="cred">ASNT Level III · UT · PT · MT · ET</span>
      <span class="muted">·</span>
      <span class="cred">Cert #331277</span>
    </p>
  </section>

  <section class="section shell closing">
    <p class="closing__line">Bring HNEC in before the audit, not after the finding.</p>
    <a href="/contact" class="btn">Request a quote →</a>
    <p class="muted closing__note">Reply within one business day. Formal quote in 24 hours.</p>
  </section>
</Layout>

<style>
  .page-head { padding-block: clamp(4rem, 3rem + 6vw, 8rem) var(--space-6); }
  .page-head__h { margin-top: var(--space-4); max-width: 22ch; }
  .page-head__lead { margin-top: var(--space-5); }

  .section-h {
    margin-top: var(--space-4);
    max-width: 22ch;
  }

  /* Service lines list */
  .lines { margin-top: var(--space-5); }
  .line {
    border-top: 1px solid var(--rule);
    padding-block: var(--space-5);
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: var(--space-5) var(--space-6);
    align-items: start;
  }
  .line:last-child { border-bottom: 1px solid var(--rule); }
  .line__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .line__n {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    color: var(--accent);
  }
  .line__name {
    font-size: var(--text-h3);
    line-height: 1.1;
  }
  .line__badge {
    color: var(--ink-muted);
  }
  .line__bullets li {
    padding-block: var(--space-2);
    border-bottom: 1px solid var(--rule);
    font-size: var(--text-md);
    letter-spacing: -0.012em;
  }
  .line__bullets li:last-child { border-bottom: none; }
  @media (max-width: 760px) {
    .line { grid-template-columns: 1fr; gap: var(--space-3); }
  }

  /* Engagement table */
  .table-wrap {
    margin-top: var(--space-5);
    overflow-x: auto;
  }
  .eng-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: var(--text-base);
  }
  .eng-table thead th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    padding: var(--space-3) var(--space-3) var(--space-3) 0;
    border-bottom: 1px solid var(--rule-strong);
    vertical-align: bottom;
  }
  .eng-table tbody th[scope="row"] {
    font-weight: 500;
    text-align: left;
    padding: var(--space-4) var(--space-3) var(--space-4) 0;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
    width: 22%;
  }
  .eng-table td {
    padding: var(--space-4) var(--space-3) var(--space-4) 0;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
    color: var(--ink);
  }
  .eng-table td:last-child, .eng-table th:last-child { padding-right: 0; }
  @media (max-width: 760px) {
    .eng-table thead { display: none; }
    .eng-table, .eng-table tbody, .eng-table tr, .eng-table th, .eng-table td { display: block; width: 100%; }
    .eng-table tr { padding-block: var(--space-4); border-bottom: 1px solid var(--rule); }
    .eng-table tbody th[scope="row"] { padding: 0 0 var(--space-2) 0; border-bottom: none; }
    .eng-table td { padding: var(--space-1) 0; border-bottom: none; }
  }

  /* Standards strip — same as Home */
  .standards {
    margin-top: var(--space-4);
    display: flex;
    flex-wrap: wrap;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .standards li {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
    padding: var(--space-3) var(--space-4) var(--space-3) 0;
    margin-right: var(--space-4);
    border-right: 1px solid var(--rule);
  }
  .standards li:last-child { border-right: none; margin-right: 0; }
  @media (max-width: 640px) {
    .standards li { border-right: none; border-bottom: 1px solid var(--rule); margin-right: 0; width: 100%; padding: var(--space-3) 0; }
    .standards li:last-child { border-bottom: none; }
  }

  .cred-line {
    margin-top: var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--ink-muted);
  }

  .closing { padding-block: var(--space-7); text-align: left; }
  .closing__line {
    margin-bottom: var(--space-5);
    font-size: var(--text-h2);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.028em;
    max-width: 22ch;
    text-wrap: balance;
  }
  .closing__note { margin-top: var(--space-3); font-size: var(--text-sm); }
</style>
