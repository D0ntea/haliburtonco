---
const nav = [
  { href: "/",         label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/about",    label: "About" },
  { href: "/press",    label: "Press" },
  { href: "/contact",  label: "Contact" },
];
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---
<header class="site-header">
  <div class="shell site-header__inner">
    <a href="/" class="site-mark" aria-label="Haliburton NDT Engineering Consultants — Home">
      <span class="site-mark__short" aria-hidden="true">HNEC</span>
      <span class="site-mark__full">Haliburton NDT Engineering Consultants</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul class="bare site-nav__list">
        {nav.map(({ href, label }) => {
          const norm = href.replace(/\/$/, "") || "/";
          const isCurrent = norm === currentPath;
          return (
            <li>
              <a href={href} class:list={["site-nav__link", { "is-current": isCurrent }]}
                 aria-current={isCurrent ? "page" : undefined}>
                {label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(150%) blur(10px);
    -webkit-backdrop-filter: saturate(150%) blur(10px);
    border-bottom: 1px solid var(--rule);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-3);
  }
  .site-mark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .site-mark:hover { color: var(--accent); text-decoration: none; }
  .site-mark__short {
    font-size: 0.95rem;
    letter-spacing: 0.18em;
    color: var(--accent);
  }
  .site-mark__full {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-muted);
    letter-spacing: 0.04em;
    text-transform: none;
  }
  .site-nav__list {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 0.5rem + 2vw, 2.5rem);
  }
  .site-nav__link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    padding-block: var(--space-2);
    border-bottom: 1px solid transparent;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
  }
  .site-nav__link:hover { color: var(--ink); text-decoration: none; }
  .site-nav__link.is-current {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 720px) {
    .site-mark__full { display: none; }
    .site-nav__list { gap: clamp(0.6rem, 0.4rem + 1.5vw, 1.25rem); }
  }
  @media (max-width: 480px) {
    .site-nav__list { gap: 0.75rem; }
    .site-nav__link { font-size: 0.6875rem; }
  }
</style>
