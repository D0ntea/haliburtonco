---
import Layout from "../layouts/Layout.astro";
import Eyebrow from "../components/Eyebrow.astro";
---
<Layout title="Contact">
  <section class="page-head shell">
    <Eyebrow number="00" label="Contact" />
    <h1 class="page-head__h">Project inquiries, audit support, training engagements.</h1>
    <p class="lead page-head__lead">
      Reply within one business day. Formal quote in 24 hours.
    </p>
  </section>

  <section class="section shell">
    <div class="grid-contact">
      <div class="card">
        <span class="card__label">Email</span>
        <a class="card__value" href="mailto:contact@haliburtonco.com">contact@haliburtonco.com</a>
      </div>

      <div class="card">
        <span class="card__label">Based</span>
        <span class="card__value card__value--plain">Denver, Colorado</span>
        <span class="muted">Engagements served nationally.</span>
      </div>
    </div>
  </section>

  <section class="section shell credentials">
    <Eyebrow number="01" label="For the record" />
    <p class="cred-block">
      <span class="cred">Haliburton NDT Engineering Consultants, LLC</span><br />
      <span class="cred muted">ASNT Level III · UT · PT · MT · ET · Cert #331277</span>
    </p>
  </section>
</Layout>

<style>
  .page-head { padding-block: clamp(4rem, 3rem + 6vw, 8rem) var(--space-6); }
  .page-head__h { margin-top: var(--space-4); max-width: 24ch; }
  .page-head__lead { margin-top: var(--space-5); }

  .grid-contact {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .card {
    padding: var(--space-5) var(--space-4);
    border-right: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .card:last-child { border-right: none; }
  .card__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .card__value {
    font-size: var(--text-h3);
    font-weight: 500;
    letter-spacing: -0.018em;
    line-height: 1.1;
    word-break: break-word;
  }
  .card__value--plain { color: var(--ink); }

  @media (max-width: 760px) {
    .grid-contact { grid-template-columns: 1fr; }
    .card { border-right: none; border-bottom: 1px solid var(--rule); }
    .card:last-child { border-bottom: none; }
  }

  .credentials .cred-block {
    margin-top: var(--space-4);
    line-height: 1.8;
  }
</style>
